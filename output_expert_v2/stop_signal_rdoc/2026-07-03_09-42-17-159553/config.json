      }
    },
    {
      "id": "go",
      "description": "Go trial: a shape (circle or square) is shown without a stop signal; respond with the key mapped to that shape (counterbalanced by group_index).",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('#jspsych-stop-signal-stimulus img')",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "go",
        "response_key_js": "(() => { if (typeof window.correct_response !== 'undefined' && window.correct_response !== null) return window.correct_response; const img = document.querySelector('#jspsych-stop-signal-stimulus img'); if (!img) return null; const src = img.src || ''; const isCircle = src.includes('circle'); const g = (window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1; const isLowGroup = (g >= 0 && g <= 4); return isCircle ? (isLowGroup ? ',' : '.') : (isLowGroup ? '.' : ','); })()"
      }
    }
  ],
