  "task_specific": {
    "key_map": {
      "task_switch_trial": "dynamic",
      "attention_check": "dynamic"
    },
    "trial_timing": {
      "max_response_time_ms": 1500,
      "fixation_ms": 500,
      "cue_CTI_ms": 150,
      "stimulus_duration_ms": 1000,
      "trial_duration_ms": 1500
    },
    "response_keys": [
      ",",
      "."
    ],
    "tasks": {
      "parity": "odd vs even (cues: Parity, Odd-Even)",
      "magnitude": "higher vs lower than 5 (cues: Magnitude, High-Low)"
    },
    "counterbalancing": {
      "source": "window.efVars.group_index (default 1)",
      "note": "getResponseMappings(group_index): 0-4 => higher/odd=',' ; 5-9 => higher=',',even=',' ; 10-14 => higher/odd='.'. The page writes the resolved per-trial key to global window.correctResponse before each stimulus, which is read directly (no client-side recomputation)."
    },
    "conditions_note": "Design factor task_switch x cue_switch (task_stay_cue_stay, task_stay_cue_switch, task_switch_cue_switch, plus 'na' first trial) is not distinguishable in the DOM; a single detection stimulus is used and true per-trial conditions are recovered from the platform export's 'condition' column.",
    "block_structure": {
      "practice_len": 4,
      "practice_accuracy_threshold": 0.75,
      "max_practice_blocks": 3,
      "num_trials_per_block": 64,
      "num_test_blocks": 3,
      "attention_check_between_test_blocks": true
    }
  },
  "pilot": {
    "min_trials": 20,
    "target_conditions": [],
    "max_blocks": 3,
    "stimulus_container_selector": "",
    "rationale": ""
  },
  "runtime": {
    "phase_detection": {
      "method": "js_eval",
      "complete": "!!document.getElementById('finished_message') || !!document.getElementById('next_experiment_button')",
      "test": "!!document.querySelector('.gng_number') && !document.querySelector('.prompt_box')",
      "loading": "typeof jsPsych === 'undefined' || (!document.querySelector('#jspsych-content') && !document.querySelector('.jspsych-display-element'))",
      "instructions": "!!document.querySelector('#jspsych-instructions-next') || !!document.querySelector('#jspsych-fullscreen-btn')",
      "practice": "!!document.querySelector('.gng_number') && !!document.querySelector('.prompt_box')",
      "feedback": "!!document.querySelector('.picture_box') || (!!document.querySelector('.center-block-text') && !document.querySelector('.gng_number'))",
      "attention_check": "!!document.querySelector('#jspsych-attention-check-rdoc-stimulus')"
    },
    "timing": {
      "poll_interval_ms": 20,
      "max_no_stimulus_polls": 600,
      "stuck_timeout_s": 10.0,
      "completion_wait_ms": 3000,
      "feedback_delay_ms": 2000,
      "omission_wait_ms": 2000,
      "rt_floor_ms": 150.0,
      "rt_cap_fraction": 0.9,
      "response_window_js": "!!document.querySelector('#jspsych-html-keyboard-response-stimulus .gng_number img')",
      "trial_context_js": "(function(){try{return 'task:'+window.currTask+' cue:'+window.currCue;}catch(e){return '';}})()",
      "viewport": {
        "width": 1280,
        "height": 800
      },
      "navigation_delay_ms": 1000,
      "attention_check_delay_ms": 1500,
      "completion_settle_ms": 2000,
      "trial_end_timeout_s": 10.0,
      "cdp_dwell_ms": 225,
      "trial_marker_js": "",
      "records_js": ""
    },
    "advance_behavior": {
      "pre_keypress_js": "",
      "advance_keys": [
        "Enter"
      ],
      "exit_pager_key": "",
      "advance_interval_polls": 100,
      "feedback_selectors": [
        "#jspsych-instructions-next",
        "#jspsych-fullscreen-btn"
      ],
      "feedback_fallback_keys": [
        "Enter"
      ]
    },
    "trial_interrupt": {
      "detection_condition": "",
      "failure_rt_key": "",
      "failure_rt_cap_fraction": 0.0,
      "inhibit_wait_ms": 0
    },
    "data_capture": {
      "method": "js_expression",
      "expression": "jsPsych.data.get().json()",
      "format": "json",
      "wait_ms": 1000
    },
    "attention_check": {
      "detection_selector": "#jspsych-attention-check-rdoc-stimulus",
      "text_selector": "#jspsych-attention-check-rdoc-stimulus",
      "response_js": "(function(){try{if(window.currentAttentionCheckData&&typeof window.currentAttentionCheckData.A!=='undefined'){return String.fromCharCode(window.currentAttentionCheckData.A).toLowerCase();}return null;}catch(e){return null;}})()",
      "stimulus_conditions": [
        "attention_check"
      ]
    },
    "navigation_stimulus_condition": "",
    "delivery_channel": "cdp",
    "calibration_n_keys": 30,
    "platform_export": {
      "row_filter": {
        "equals": {
          "trial_id": "test_trial"
        }
      },
      "fields": {
        "condition": {
          "column": "condition"
        },
        "rt": {
          "column": "rt",
          "parse": "float"
        },
        "correct": {
          "column": "correct_trial",
          "parse": "truthy"
        },
        "CTI": {
          "column": "CTI",
          "parse": "float"
        }
      }
    }
  }
