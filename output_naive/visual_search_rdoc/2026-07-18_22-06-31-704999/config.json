  "stimuli": [
    {
      "id": "feature",
      "description": "Feature-search array (homogeneous black distractors, possibly containing a white vertical target).",
      "detection": {
        "method": "js_eval",
        "selector": "(!!document.querySelector('#jspsych-html-keyboard-response-stimulus .container .box')) && (window.condition === 'feature')",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "feature",
        "response_key_js": "(() => { const s = document.querySelector('#jspsych-html-keyboard-response-stimulus'); if (!s) return null; const present = !!s.querySelector('#target'); const g = (typeof window.group_index === 'number') ? window.group_index : ((window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1); const low = (g >= 0 && g <= 4); return low ? (present ? '.' : ',') : (present ? ',' : '.'); })()"
      }
    },
    {
      "id": "conjunction",
      "description": "Conjunction-search array (mixed black-vertical and white-horizontal distractors, possibly containing a white vertical target).",
      "detection": {
        "method": "js_eval",
        "selector": "(!!document.querySelector('#jspsych-html-keyboard-response-stimulus .container .box')) && (window.condition === 'conjunction')",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "conjunction",
        "response_key_js": "(() => { const s = document.querySelector('#jspsych-html-keyboard-response-stimulus'); if (!s) return null; const present = !!s.querySelector('#target'); const g = (typeof window.group_index === 'number') ? window.group_index : ((window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1); const low = (g >= 0 && g <= 4); return low ? (present ? '.' : ',') : (present ? ',' : '.'); })()"
      }
    }
  ],
