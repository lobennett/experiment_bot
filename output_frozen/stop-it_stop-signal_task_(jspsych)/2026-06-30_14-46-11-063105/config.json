{
  "task": {
    "name": "STOP-IT Stop-Signal Task (jsPsych)",
    "constructs": [],
    "reference_literature": [],
    "platform": "",
    "paradigm_classes": [
      "response_inhibition",
      "speeded_choice"
    ]
  },
  "stimuli": [
    {
      "id": "stop",
      "description": "Red stop-signal arrow (left or right) that replaces the white go arrow after the stop-signal delay; participant must withhold the response.",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector(\"img[src*='stop_left'], img[src*='stop_right']\")",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "stop",
        "response_key_js": "(function(){var m=document.querySelector(\"#jspsych-image-keyboard-response-stimulus\");if(!m)return null;var s=m.src||\"\";if(s.indexOf(\"left\")!==-1)return \"ArrowLeft\";if(s.indexOf(\"right\")!==-1)return \"ArrowRight\";return null;})()"
      }
    },
    {
      "id": "go",
      "description": "White go arrow (left or right). Left arrow -> ArrowLeft, right arrow -> ArrowRight. Appears on every trial; on stop trials it is later overwritten by the red stop arrow.",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector(\"img[src*='go_left'], img[src*='go_right']\")",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "go",
        "response_key_js": "(function(){var m=document.querySelector(\"#jspsych-image-keyboard-response-stimulus\");if(!m)return null;var s=m.src||\"\";if(s.indexOf(\"left\")!==-1)return \"ArrowLeft\";if(s.indexOf(\"right\")!==-1)return \"ArrowRight\";return null;})()"
      }
    }
  ],
  "response_distributions": {
    "go": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 430.0,
        "sigma": 45.0,
        "tau": 95.0
      },
      "unit": "ms"
    },
    "stop": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 360.0,
        "sigma": 40.0,
        "tau": 70.0
      },
      "unit": "ms"
    }
  },
  "performance": {
    "accuracy": {
      "go": 0.97,
      "stop": 0.5
    },
    "omission_rate": {
      "go": 0.01,
      "stop": 0.0
    }
  },
