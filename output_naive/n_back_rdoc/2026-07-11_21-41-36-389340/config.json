{
  "task": {
    "name": "n_back_rdoc",
    "constructs": [],
    "reference_literature": [],
    "platform": "",
    "paradigm_classes": [
      "speeded two-choice task",
      "working-memory continuous matching task",
      "delayed match-to-sample with variable memory load"
    ]
  },
  "stimuli": [
    {
      "id": "match",
      "description": "Letter image whose current-trial n-back condition is 'match' (current letter equals the letter shown `delay` trials ago, ignoring case).",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector(\"#jspsych-html-keyboard-response-stimulus img[src*='n_back_rdoc/images']\") && window.nbackCondition === 'match'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "match",
        "response_key_js": "(typeof window.correctResponse !== 'undefined' && window.correctResponse !== null ? String(window.correctResponse) : null)"
      }
    },
    {
      "id": "mismatch",
      "description": "Letter image whose current-trial n-back condition is 'mismatch' (current letter differs from the letter shown `delay` trials ago).",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector(\"#jspsych-html-keyboard-response-stimulus img[src*='n_back_rdoc/images']\") && window.nbackCondition === 'mismatch'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "mismatch",
        "response_key_js": "(typeof window.correctResponse !== 'undefined' && window.correctResponse !== null ? String(window.correctResponse) : null)"
      }
    },
    {
      "id": "buffer",
      "description": "Buffer/warm-up letter image at the start of each block (nbackCondition == 'N/A'); the first `delay` trials of every block. These require the 'mismatch' key per instructions and are excluded from analysis.",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector(\"#jspsych-html-keyboard-response-stimulus img[src*='n_back_rdoc/images']\") && window.nbackCondition === 'N/A'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "buffer",
        "response_key_js": "(typeof window.correctResponse !== 'undefined' && window.correctResponse !== null ? String(window.correctResponse) : null)"
      }
    }
  ],
  "response_distributions": {},
  "performance": {
    "accuracy": {}
  },
  "navigation": {
    "phases": [
      {
        "phase": "enter_fullscreen",
        "action": "click",
        "target": "#jspsych-fullscreen-btn",
        "key": "",
        "steps": [],
        "duration_ms": 0
      },
      {
        "phase": "instructions_next",
        "action": "click",
        "target": "#jspsych-instructions-next",
        "key": "",
