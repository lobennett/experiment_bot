  "task_specific": {
    "key_map": {
      "congruent": "dynamic",
      "incongruent": "dynamic"
    },
    "trial_timing": {
      "fixation_duration_ms": 500,
      "stimulus_duration_ms": 1000,
      "trial_duration_ms": 1500,
      "max_response_time_ms": 1500
    },
    "counterbalancing": {
      "variable": "window.efVars.group_index",
      "default": 1,
      "rule": "group_index 0-4: center H -> comma (,), center F -> period (.); group_index 5-14: center H -> period (.), center F -> comma (,)"
    },
