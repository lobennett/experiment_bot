  "task": {
    "name": "flanker_rdoc",
    "constructs": [],
    "reference_literature": [],
    "platform": "",
    "paradigm_classes": [
      "speeded two-choice task",
      "response-conflict task with distractor flankers"
    ]
  },
  "stimuli": [
    {
      "id": "congruent",
      "description": "Five-letter array whose central letter matches the flanking letters (e.g. HHHHH or FFFFF).",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { const m = document.querySelector('.flankerMiddle img'); const l = document.querySelector('.flankerLeft_2 img'); if (!m || !l) return false; return (m.src||'').includes('/H.png') === (l.src||'').includes('/H.png'); })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "congruent",
        "response_key_js": "(() => { const m = document.querySelector('.flankerMiddle img'); if (!m) return null; const isH = (m.src||'').includes('/H.png'); const g = (window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1; const isLowGroup = (g >= 0 && g <= 4); return isH ? (isLowGroup ? ',' : '.') : (isLowGroup ? '.' : ','); })()"
      }
    },
    {
      "id": "incongruent",
      "description": "Five-letter array whose central letter differs from the flanking letters (e.g. FFHFF or HHFHH).",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { const m = document.querySelector('.flankerMiddle img'); const l = document.querySelector('.flankerLeft_2 img'); if (!m || !l) return false; return (m.src||'').includes('/H.png') !== (l.src||'').includes('/H.png'); })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "incongruent",
        "response_key_js": "(() => { const m = document.querySelector('.flankerMiddle img'); if (!m) return null; const isH = (m.src||'').includes('/H.png'); const g = (window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1; const isLowGroup = (g >= 0 && g <= 4); return isH ? (isLowGroup ? ',' : '.') : (isLowGroup ? '.' : ','); })()"
      }
    }
  ],
