      "max_no_stimulus_polls": 300,
      "stuck_timeout_s": 10.0,
      "completion_wait_ms": 2000,
      "feedback_delay_ms": 2000,
      "omission_wait_ms": 2000,
      "rt_floor_ms": 150.0,
