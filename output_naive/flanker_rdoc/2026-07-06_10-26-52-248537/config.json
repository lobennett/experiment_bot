  "runtime": {
    "phase_detection": {
      "method": "js_eval",
      "complete": "(!!document.getElementById('finished_message')) || (document.body && document.body.innerText.includes('Experiment Complete'))",
      "test": "(!!document.querySelector('.flankerMiddle img')) && !document.querySelector('.prompt_box')",
      "loading": "!!document.querySelector('.lds-dual-ring') && !document.getElementById('finished_message')",
      "instructions": "(!!document.querySelector('#jspsych-instructions-next')) || (!!document.querySelector('.jspsych-instructions-nav'))",
      "practice": "!!document.querySelector('.prompt_box')",
      "feedback": "(() => { const el = document.querySelector('#jspsych-content'); if (!el) return false; const t = el.innerText || ''; return t.includes('Press') && (t.includes('to begin practice') || t.includes('completed') || t.includes('read your feedback') || t.includes('test portion')); })()",
      "attention_check": "!!document.querySelector('#jspsych-attention-check-rdoc-stimulus')"
    },
    "timing": {
      "poll_interval_ms": 20,
      "max_no_stimulus_polls": 400,
      "stuck_timeout_s": 10.0,
      "completion_wait_ms": 6000,
      "feedback_delay_ms": 2000,
      "omission_wait_ms": 2000,
      "rt_floor_ms": 150.0,
      "rt_cap_fraction": 0.9,
      "response_window_js": "(() => !!document.querySelector('.flankerMiddle img'))()",
      "trial_context_js": "(() => { const m = document.querySelector('.flankerMiddle img'); const l = document.querySelector('.flankerLeft_2 img'); if (!m || !l) return ''; const mid = (m.src||'').includes('/H.png') ? 'H' : 'F'; const fl = (l.src||'').includes('/H.png') ? 'H' : 'F'; return (mid === fl ? 'congruent' : 'incongruent') + ':center=' + mid; })()",
      "viewport": {
        "width": 1280,
        "height": 800
      },
      "navigation_delay_ms": 1000,
      "attention_check_delay_ms": 1500,
      "completion_settle_ms": 2000,
      "trial_end_timeout_s": 8.0,
      "cdp_dwell_ms": 225.0,
      "trial_marker_js": "",
      "records_js": ""
    },
    "advance_behavior": {
