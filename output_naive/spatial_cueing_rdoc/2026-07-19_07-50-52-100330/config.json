{
  "task": {
    "name": "spatial_cueing_rdoc",
    "constructs": [],
    "reference_literature": [],
    "platform": "",
    "paradigm_classes": [
      "speeded two-alternative spatial localization task",
      "pre-target spatial cueing manipulation"
    ]
  },
  "stimuli": [
    {
      "id": "nocue",
      "description": "Target star appears in one box on a trial with no preceding cue",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('.star') && !!(window.currStim && window.currStim.data) && window.currStim.data.condition === 'nocue'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "nocue",
        "response_key_js": "(function(){try{ return (window.currStim && window.currStim.data && typeof window.currStim.data.correct_response !== 'undefined') ? window.currStim.data.correct_response : null; }catch(e){ return null; }})()"
      }
    },
    {
      "id": "doublecue",
      "description": "Target star appears after both boxes were highlighted (double cue)",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('.star') && !!(window.currStim && window.currStim.data) && window.currStim.data.condition === 'doublecue'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "doublecue",
        "response_key_js": "(function(){try{ return (window.currStim && window.currStim.data && typeof window.currStim.data.correct_response !== 'undefined') ? window.currStim.data.correct_response : null; }catch(e){ return null; }})()"
      }
    },
    {
      "id": "valid",
      "description": "Target star appears in the box that was validly cued",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('.star') && !!(window.currStim && window.currStim.data) && window.currStim.data.condition === 'valid'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "valid",
        "response_key_js": "(function(){try{ return (window.currStim && window.currStim.data && typeof window.currStim.data.correct_response !== 'undefined') ? window.currStim.data.correct_response : null; }catch(e){ return null; }})()"
      }
    },
    {
      "id": "invalid",
      "description": "Target star appears in the box opposite to the (invalidly) cued box",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('.star') && !!(window.currStim && window.currStim.data) && window.currStim.data.condition === 'invalid'",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "invalid",
        "response_key_js": "(function(){try{ return (window.currStim && window.currStim.data && typeof window.currStim.data.correct_response !== 'undefined') ? window.currStim.data.correct_response : null; }catch(e){ return null; }})()"
      }
    }
  ],
  "response_distributions": {},
  "performance": {
    "accuracy": {}
  },
  "navigation": {
    "phases": [
      {
        "phase": "fullscreen_prompt",
        "action": "click",
        "target": "#jspsych-fullscreen-btn",
        "key": "",
        "steps": [],
        "duration_ms": 0
      }
    ]
  },
  "task_specific": {
    "key_map": {
      "nocue": "dynamic",
      "doublecue": "dynamic",
      "valid": "dynamic",
      "invalid": "dynamic"
    },
    "trial_timing": {
      "max_response_time_ms": 1500,
      "fixation_duration_ms": 500,
      "cue_stimulus_duration_ms": 100,
      "cue_trial_duration_ms": 100,
      "cti_duration_ms": 400,
      "stim_stimulus_duration_ms": 1000,
      "stim_trial_duration_ms": 1500
    },
    "response_keys": {
      "left_box": ",",
      "right_box": "."
    },
    "structure_notes": "12 practice trials (auto-repeats up to 3x until accuracy >= 0.83), then 3 test blocks of 72 trials each. Each test block begins with an attention check. Correct key depends on stim_location (left=',' right='.'), read authoritatively from currStim.data.correct_response."
  },
  "pilot": {
    "min_trials": 20,
    "target_conditions": [],
    "max_blocks": 3,
    "stimulus_container_selector": "",
    "rationale": ""
  },
  "runtime": {
    "phase_detection": {
      "method": "js_eval",
      "complete": "!!document.getElementById('finished_message') || (!!document.body && /Experiment Complete/i.test(document.body.innerText || ''))",
      "test": "!!document.querySelector('.star') && !document.querySelector('.prompt_box')",
      "loading": "!!document.querySelector('#jspsych-fullscreen-btn')",
      "instructions": "!!document.querySelector('#jspsych-instructions-next') || !!document.querySelector('.jspsych-instructions-nav')",
      "practice": "!!document.querySelector('.prompt_box')",
      "feedback": "!(document.getElementById('finished_message')) && !!document.body && (/Press\\s*<?i?>?enter/i.test(document.body.innerText || '') || /out of\\s*\\d+\\s*blocks/i.test(document.body.innerText || '') || /Correct!|Incorrect|Respond Faster/i.test(document.body.innerText || ''))",
      "attention_check": "!!document.querySelector('#jspsych-attention-check-rdoc-stimulus')"
    },
    "timing": {
      "poll_interval_ms": 20,
      "max_no_stimulus_polls": 2000,
      "stuck_timeout_s": 10.0,
      "completion_wait_ms": 5000,
      "feedback_delay_ms": 2000,
      "omission_wait_ms": 2000,
      "rt_floor_ms": 150.0,
      "rt_cap_fraction": 0.9,
      "response_window_js": "!!document.querySelector('.star')",
      "trial_context_js": "(function(){try{ return (window.currStim && window.currStim.data) ? (window.currStim.data.condition + '/' + window.currStim.data.stim_location) : ''; }catch(e){ return ''; }})()",
      "viewport": {
        "width": 1280,
        "height": 800
      },
      "navigation_delay_ms": 1000,
      "attention_check_delay_ms": 1500,
      "completion_settle_ms": 3000,
      "trial_end_timeout_s": 8.0,
      "cdp_dwell_ms": 225.0,
      "trial_marker_js": "",
      "records_js": ""
    },
    "advance_behavior": {
      "pre_keypress_js": "",
      "advance_keys": [
        "Enter"
      ],
      "exit_pager_key": "",
      "advance_interval_polls": 100,
      "feedback_selectors": [
        "#jspsych-instructions-next"
      ],
      "feedback_fallback_keys": [
        "Enter"
      ]
    },
    "trial_interrupt": {
      "detection_condition": "",
      "failure_rt_key": "",
      "failure_rt_cap_fraction": 0.0,
      "inhibit_wait_ms": 0
    },
    "data_capture": {
      "method": "js_expression",
      "expression": "jsPsych.data.get().json()",
      "format": "json",
      "wait_ms": 1000
    },
    "attention_check": {
      "detection_selector": "#jspsych-attention-check-rdoc-stimulus",
      "text_selector": "#jspsych-attention-check-rdoc-stimulus",
      "response_js": "(function(){try{ return (window.currentAttentionCheckData && typeof window.currentAttentionCheckData.A !== 'undefined') ? String.fromCharCode(window.currentAttentionCheckData.A).toLowerCase() : null; }catch(e){ return null; }})()",
      "stimulus_conditions": []
    },
    "navigation_stimulus_condition": "",
    "delivery_channel": "cdp",
    "calibration_n_keys": 30,
    "platform_export": {
      "row_filter": {
        "equals": {
          "trial_id": "test_trial"
        }
      },
      "fields": {
        "condition": {
          "column": "condition"
        },
        "rt": {
          "column": "rt",
          "parse": "float"
        },
        "correct": {
          "column": "correct_trial",
          "parse": "truthy"
        }
      }
    }
  }
}