      "response_window_js": "!!document.querySelector(\"img[src*='go_left'], img[src*='go_right'], img[src*='stop_left'], img[src*='stop_right']\")",
      "trial_context_js": "(function(){try{var t=jsPsych.currentTrial();return (t&&t.data?(\"signal=\"+t.data.signal):\"\")+\" SSD=\"+(window.SSD||\"\");}catch(e){return \"\";}})()",
      "viewport": {
        "width": 1280,
        "height": 800
      },
      "navigation_delay_ms": 1000,
      "attention_check_delay_ms": 1500,
      "completion_settle_ms": 2000,
      "trial_end_timeout_s": 5.0,
      "cdp_dwell_ms": 50.0,
      "trial_marker_js": "() => (window.jsPsych && window.jsPsych.progress && window.jsPsych.progress().current_trial_global) || null",
      "records_js": "() => (window.jsPsych && jsPsych.data) ? jsPsych.data.get().values() : []"
    },
    "advance_behavior": {
