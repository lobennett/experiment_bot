{
  "task": {
    "name": "Stop Signal Task",
    "platform": "psytoolkit",
    "constructs": [
      "response inhibition",
      "cognitive control",
      "executive function",
      "impulsivity"
    ],
    "reference_literature": [
      "Logan, G. D., & Cowan, W. B. (1984). On the ability to inhibit thought and action: A theory of an act of control. Psychological Review, 91(3), 295-327.",
      "Verbruggen, F., & Logan, G. D. (2008). Response inhibition in the stop-signal paradigm. Trends in Cognitive Sciences, 12(11), 418-424."
    ]
  },
  "stimuli": [
    {
      "id": "go_left",
      "description": "Left arrow go stimulus - press B",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { try { return (typeof task_go !== 'undefined' && task_go.step === 8 && typeof tablerow !== 'undefined' && t_gotable[tablerow].c3 === 1) || (typeof task_nogo !== 'undefined' && task_nogo.step === 8 && typeof tablerow !== 'undefined' && t_nogotable[tablerow].c3 === 1); } catch(e) { return false; } })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "b",
        "condition": "go_left"
      }
    },
    {
      "id": "go_right",
      "description": "Right arrow go stimulus - press N",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { try { return (typeof task_go !== 'undefined' && task_go.step === 8 && typeof tablerow !== 'undefined' && t_gotable[tablerow].c3 === 2) || (typeof task_nogo !== 'undefined' && task_nogo.step === 8 && typeof tablerow !== 'undefined' && t_nogotable[tablerow].c3 === 2); } catch(e) { return false; } })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "n",
        "condition": "go_right"
      }
    },
    {
      "id": "stop_signal",
      "description": "Stop signal has appeared (nogo stimulus after arrow) - withhold response",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { try { return typeof task_nogo !== 'undefined' && task_nogo.step >= 9 && task_nogo.step <= 10; } catch(e) { return false; } })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "stop"
      }
    }
  ],
  "response_distributions": {
    "go_correct": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 320,
        "sigma": 40,
        "tau": 50
      },
      "unit": "ms"
    },
    "go_error": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 300,
        "sigma": 45,
        "tau": 55
      },
      "unit": "ms"
    },
    "stop_failure": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 280,
        "sigma": 35,
        "tau": 40
      },
      "unit": "ms"
    }
  },
  "performance": {
    "go_accuracy": 0.95,
    "stop_accuracy": 0.5,
    "omission_rate": 0.02,
    "practice_accuracy": 0.9
  },
  "navigation": {
    "phases": [
      {
        "phase": "click_start",
        "action": "click",
        "target": "button",
        "key": "",
        "steps": [],
        "duration_ms": 2000
      },
      {
        "phase": "wait_for_canvas",
        "action": "wait",
        "target": "canvas#exp",
        "key": "",
        "steps": [],
        "duration_ms": 3000
      },
      {
        "phase": "focus_canvas",
        "action": "click",
        "target": "canvas#exp",
        "key": "",
        "steps": [],
        "duration_ms": 1000
      },
      {
        "phase": "instructions_1",
        "action": "keypress",
        "target": "",
        "key": " ",
        "steps": [],
        "duration_ms": 3000,
        "pre_js": "psy_expect_keyboard()"
      },
      {
        "phase": "instructions_2",
        "action": "keypress",
        "target": "",
        "key": " ",
        "steps": [],
        "duration_ms": 3000,
        "pre_js": "psy_expect_keyboard()"
      },
      {
        "phase": "start_task",
        "action": "keypress",
        "target": "",
        "key": "q",
        "steps": [],
        "duration_ms": 3000,
        "pre_js": "psy_expect_keyboard()"
      }
    ]
  },
  "task_specific": {
    "paradigm": "stop_signal_task",
    "stop_signal_type": "visual",
    "ssrt_target_ms": 240,
    "response_keys": {
      "left": "b",
      "right": "n"
    },
    "stop_proportion": 0.25,
    "go_proportion": 0.75,
    "trial_timing": {
      "fixation_duration_ms": 500,
      "max_response_time_ms": 500,
      "inter_trial_interval_ms": 750
    },
    "ssd_type": "random",
    "ssd_range_ms": [100, 450],
    "ssd_step_ms": 50,
    "block_structure": {
      "practice_trials": 50,
      "test_go_trials": 30,
      "test_nogo_trials": 10,
      "test_trials_per_block": 40,
      "number_of_test_blocks": 1
    }
  }
}
