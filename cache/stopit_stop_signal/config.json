{
  "task": {
    "name": "Stop-Signal Task (STOP-IT)",
    "constructs": [
      "response inhibition",
      "motor control",
      "proactive and reactive control",
      "stop-signal reaction time (SSRT)"
    ],
    "reference_literature": [
      "Logan & Cowan (1984). On the ability to inhibit thought and action: A theory of an act of control. Psychological Review.",
      "Verbruggen & Logan (2008). Response inhibition in the stop-signal paradigm. Trends in Cognitive Sciences.",
      "Verbruggen et al. (2019). A consensus guide to capturing the ability to inhibit actions and impulsive behaviors in the stop-signal task. eLife.",
      "Rabbitt (1966). Errors and error correction in choice-response tasks. JEP."
    ],
    "platform": "jsPsych 6.0.5"
  },
  "stimuli": [
    {
      "id": "stop_left",
      "description": "Stop signal trial with leftward arrow (red arrow appears after SSD)",
      "detection": {
        "method": "dom_query",
        "selector": "img#jspsych-image-keyboard-response-stimulus[src*='stop_left']",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "stop_signal"
      }
    },
    {
      "id": "stop_right",
      "description": "Stop signal trial with rightward arrow (red arrow appears after SSD)",
      "detection": {
        "method": "dom_query",
        "selector": "img#jspsych-image-keyboard-response-stimulus[src*='stop_right']",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "stop_signal"
      }
    },
    {
      "id": "go_left",
      "description": "Go trial with leftward white arrow \u2014 respond with left arrow key",
      "detection": {
        "method": "dom_query",
        "selector": "img#jspsych-image-keyboard-response-stimulus[src*='go_left']",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "ArrowLeft",
        "condition": "go"
      }
    },
    {
      "id": "go_right",
      "description": "Go trial with rightward white arrow \u2014 respond with right arrow key",
      "detection": {
        "method": "dom_query",
        "selector": "img#jspsych-image-keyboard-response-stimulus[src*='go_right']",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "ArrowRight",
        "condition": "go"
      }
    }
  ],
  "response_distributions": {
    "go": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 450,
        "sigma": 60,
        "tau": 90
      },
      "unit": "ms"
    },
    "stop_signal": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 430,
        "sigma": 55,
        "tau": 80
      },
      "unit": "ms"
    }
  },
  "performance": {
    "accuracy": {
      "go": 0.97,
      "stop_signal": 0.5
    },
    "practice_accuracy": 0.95,
    "omission_rate": {
      "go": 0.01,
      "stop_signal": 0.0
    }
  },
  "navigation": {
    "phases": [
      {
        "phase": "welcome",
        "action": "click",
        "target": "button#jspsych-instructions-next",
        "key": "",
        "steps": [],
        "duration_ms": 0
      },
      {
        "phase": "fullscreen",
        "action": "click",
        "target": "button#jspsych-fullscreen-btn",
        "key": "",
        "steps": [],
        "duration_ms": 0
      },
      {
        "phase": "instructions",
        "action": "click",
        "target": "button#jspsych-instructions-next",
        "key": "",
        "steps": [],
        "duration_ms": 0
      },
      {
        "phase": "block_start",
        "action": "keypress",
        "target": "",
        "key": " ",
        "steps": [],
        "duration_ms": 0
      }
    ]
  },
  "task_specific": {
    "key_map": {
      "go": "dynamic",
      "stop_signal": "none"
    },
    "trial_timing": {
      "max_response_time_ms": 1250,
      "fixation_ms": 250,
      "iti_ms": 500
    },
    "staircase": {
      "start_ssd_ms": 200,
      "step_ms": 50,
      "target_p_respond": 0.5
    }
  },
  "temporal_effects": {
    "autocorrelation": {
      "enabled": true,
      "phi": 0.2,
      "rationale": "Gilden (2001) and Wagenmakers et al. (2004) report modest lag-1 positive autocorrelation in choice RT series."
    },
    "fatigue_drift": {
      "enabled": true,
      "drift_per_trial_ms": 0.15,
      "rationale": "Slight RT drift over ~320 trials consistent with time-on-task effects reported in sustained RT tasks."
    },
    "post_error_slowing": {
      "enabled": true,
      "slowing_ms_min": 20,
      "slowing_ms_max": 60,
      "rationale": "Rabbitt (1966); Danielmeier & Ullsperger (2011). Post-error slowing typically 20-60 ms in choice RT tasks."
    },
    "condition_repetition": {
      "enabled": false,
      "facilitation_ms": 0,
      "cost_ms": 0,
      "rationale": "Stop-signal trial type is unpredictable by design; repetition effects are minimal and dominated by the SSD staircase dynamics."
    },
    "pink_noise": {
      "enabled": true,
      "sd_ms": 18,
      "hurst": 0.75,
      "rationale": "Gilden (2001): 1/f structure in RT series is a robust feature of human performance."
    },
    "post_interrupt_slowing": {
      "enabled": true,
      "slowing_ms_min": 30,
      "slowing_ms_max": 80,
      "rationale": "Verbruggen & Logan (2008): successful stopping reliably slows the subsequent go-trial RT, often larger than post-error slowing."
    }
  },
  "between_subject_jitter": {
    "rt_mean_sd_ms": 50,
    "rt_condition_sd_ms": 15,
    "sigma_tau_range": [
      0.85,
      1.2
    ],
    "accuracy_sd": 0.02,
    "omission_sd": 0.005,
    "rationale": "Individual differences in baseline RT in stop-signal tasks show SDs around 50-80 ms across healthy adults (Congdon et al., 2012); accuracy is near ceiling with low between-subject variability."
  },
  "pilot": {
    "min_trials": 16,
    "target_conditions": [
      "go",
      "stop_signal"
    ],
    "max_blocks": 1,
    "stimulus_container_selector": "#jspsych-content",
    "rationale": "Practice block has NdesignReps_practice=4 * 8 = 32 trials with 1/4 stop ratio, so ~16 trials observes both conditions reliably."
  },
  "runtime": {
    "phase_detection": {
      "method": "js_eval",
      "complete": "document.body.innerText.includes('Thank you for your participation')",
      "test": "!!document.querySelector('img#jspsych-image-keyboard-response-stimulus')",
      "loading": "!document.querySelector('#jspsych-content') || document.querySelector('#jspsych-content').innerHTML === ''",
      "instructions": "!!document.querySelector('button#jspsych-instructions-next') || !!document.querySelector('button#jspsych-fullscreen-btn')",
      "practice": "!!document.querySelector('img#jspsych-image-keyboard-response-stimulus') && (typeof block_ind !== 'undefined' && block_ind === 0)",
      "feedback": "document.body.innerText.includes('GO TRIALS:') || document.body.innerText.includes('Average response time')",
      "attention_check": "false"
    },
    "timing": {
      "poll_interval_ms": 20,
      "max_no_stimulus_polls": 1500,
      "stuck_timeout_s": 10.0,
      "completion_wait_ms": 5000,
      "feedback_delay_ms": 2000,
      "omission_wait_ms": 2000,
      "rt_floor_ms": 150.0,
      "rt_cap_fraction": 0.9,
      "response_window_js": "(function(){var i=document.querySelector('img#jspsych-image-keyboard-response-stimulus');return !!i && !/fix\\.png/.test(i.src);})()",
      "trial_context_js": "",
      "viewport": {
        "width": 1280,
        "height": 800
      }
    },
    "advance_behavior": {
      "pre_keypress_js": "",
      "advance_keys": [
        " "
      ],
      "exit_pager_key": "",
      "advance_interval_polls": 80,
      "feedback_selectors": [
        "button#jspsych-instructions-next",
        "button#jspsych-fullscreen-btn"
      ],
      "feedback_fallback_keys": [
        " "
      ]
    },
    "trial_interrupt": {
      "detection_condition": "stop_signal",
      "failure_rt_key": "stop_signal",
      "failure_rt_cap_fraction": 0.85,
      "inhibit_wait_ms": 1300
    },
    "data_capture": {
      "method": "js_expression",
      "expression": "jsPsych.data.get().filter({trial_type: 'custom-stop-signal-plugin'}).csv()",
      "format": "csv",
      "wait_ms": 1000
    },
    "attention_check": {}
  }
}