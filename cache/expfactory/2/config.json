{
  "task": {
    "name": "Cued Task Switching (RDoC)",
    "platform": "expfactory",
    "constructs": [
      "cognitive flexibility",
      "task switching",
      "executive function",
      "cognitive control"
    ],
    "reference_literature": [
      "Monsell, S. (2003). Task switching. Trends in Cognitive Sciences, 7(3), 134-140.",
      "Meiran, N. (1996). Reconfiguration of processing mode prior to task performance. Journal of Experimental Psychology: Learning, Memory, and Cognition, 22(6), 1423-1442.",
      "Kiesel, A., Steinhauser, M., Wendt, M., Falkenstein, M., Jost, K., Philipp, A. M., & Koch, I. (2010). Control and interference in task switching\u2014A review. Psychological Bulletin, 136(5), 849-874.",
      "Altmann, E. M. (2007). Cue-independent task-specific representations in task switching: Evidence from backward inhibition. Journal of Experimental Psychology: Human Perception and Performance, 33(6), 1353-1368."
    ]
  },
  "stimuli": [
    {
      "id": "parity_even_number",
      "description": "Even number (2,4,6,8) with parity cue (Parity or Odd-Even) - response depends on group_index mapping",
      "detection": {
        "method": "js_eval",
        "selector": "window.currTask === 'parity' && window.currStim.number % 2 === 0",
        "alt_method": "text_content",
        "pattern": "Parity|Odd-Even"
      },
      "response": {
        "key": "dynamic",
        "condition": "parity_even"
      }
    },
    {
      "id": "parity_odd_number",
      "description": "Odd number (1,3,7,9) with parity cue (Parity or Odd-Even)",
      "detection": {
        "method": "js_eval",
        "selector": "window.currTask === 'parity' && window.currStim.number % 2 !== 0",
        "alt_method": "text_content",
        "pattern": "Parity|Odd-Even"
      },
      "response": {
        "key": "dynamic",
        "condition": "parity_odd"
      }
    },
    {
      "id": "magnitude_high_number",
      "description": "Number greater than 5 (6,7,8,9) with magnitude cue (Magnitude or High-Low)",
      "detection": {
        "method": "js_eval",
        "selector": "window.currTask === 'magnitude' && window.currStim.number > 5",
        "alt_method": "text_content",
        "pattern": "Magnitude|High-Low"
      },
      "response": {
        "key": "dynamic",
        "condition": "magnitude_high"
      }
    },
    {
      "id": "magnitude_low_number",
      "description": "Number less than 5 (1,2,3,4) with magnitude cue (Magnitude or High-Low)",
      "detection": {
        "method": "js_eval",
        "selector": "window.currTask === 'magnitude' && window.currStim.number < 5",
        "alt_method": "text_content",
        "pattern": "Magnitude|High-Low"
      },
      "response": {
        "key": "dynamic",
        "condition": "magnitude_low"
      }
    },
    {
      "id": "fixation",
      "description": "Fixation cross displayed between trials",
      "detection": {
        "method": "dom_query",
        "selector": "div.fixation",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "no_response"
      }
    },
    {
      "id": "cue_display",
      "description": "Cue word displayed before stimulus (Parity, Odd-Even, Magnitude, High-Low)",
      "detection": {
        "method": "dom_query",
        "selector": "div.upperbox div.center-text",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "no_response"
      }
    },
    {
      "id": "feedback_correct",
      "description": "Correct feedback during practice",
      "detection": {
        "method": "text_content",
        "selector": "div.center-text",
        "alt_method": "",
        "pattern": "Correct!"
      },
      "response": {
        "key": null,
        "condition": "no_response"
      }
    },
    {
      "id": "feedback_incorrect",
      "description": "Incorrect feedback during practice",
      "detection": {
        "method": "text_content",
        "selector": "div.center-text",
        "alt_method": "",
        "pattern": "Incorrect"
      },
      "response": {
        "key": null,
        "condition": "no_response"
      }
    },
    {
      "id": "feedback_slow",
      "description": "Too slow feedback during practice",
      "detection": {
        "method": "text_content",
        "selector": "div.center-text",
        "alt_method": "",
        "pattern": "Respond Faster!"
      },
      "response": {
        "key": null,
        "condition": "no_response"
      }
    },
    {
      "id": "attention_check",
      "description": "Attention check question between test blocks",
      "detection": {
        "method": "dom_query",
        "selector": "#jspsych-attention-check-rdoc-stimulus",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "dynamic",
        "condition": "attention_check_response"
      }
    }
  ],
  "response_distributions": {
    "task_repeat_cue_repeat": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 530,
        "sigma": 55,
        "tau": 85
      },
      "unit": "ms"
    },
    "task_repeat_cue_switch": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 550,
        "sigma": 55,
        "tau": 90
      },
      "unit": "ms"
    },
    "task_switch": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 555,
        "sigma": 60,
        "tau": 95
      },
      "unit": "ms"
    },
    "first_trial": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 555,
        "sigma": 65,
        "tau": 95
      },
      "unit": "ms"
    }
  },
  "performance": {
    "go_accuracy": 0.92,
    "stop_accuracy": 0,
    "omission_rate": 0.005,
    "practice_accuracy": 0.90
