  "task": {
    "name": "cued_task_switching_rdoc",
    "constructs": [],
    "reference_literature": [],
    "platform": "",
    "paradigm_classes": [
      "speeded two-choice classification",
      "cued task-switching paradigm",
      "trial-by-trial cued response task"
    ]
  },
  "stimuli": [
    {
      "id": "attention_check",
      "description": "Between-block attention check asking the participant to press a specific key.",
      "detection": {
        "method": "dom_query",
        "selector": "#jspsych-attention-check-rdoc-stimulus",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "attention_check",
        "response_key_js": "(function(){try{if(window.currentAttentionCheckData&&typeof window.currentAttentionCheckData.A!=='undefined'){return String.fromCharCode(window.currentAttentionCheckData.A).toLowerCase();}return null;}catch(e){return null;}})()"
      }
    },
    {
      "id": "task_switch_trial",
      "description": "Digit stimulus (number image) shown after the cue; responded to by comma or period depending on the current task and counterbalanced key mapping.",
      "detection": {
        "method": "dom_query",
        "selector": "#jspsych-html-keyboard-response-stimulus .gng_number img",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "task_switch_trial",
        "response_key_js": "(typeof window.correctResponse !== 'undefined' && window.correctResponse !== null ? window.correctResponse : null)"
      }
    }
  ],
