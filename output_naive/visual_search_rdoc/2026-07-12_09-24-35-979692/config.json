{
  "task": {
    "name": "visual_search_rdoc",
    "constructs": [],
    "reference_literature": [],
    "platform": "",
    "paradigm_classes": [
      "speeded two-alternative decision task",
      "visual search with target present/absent judgment",
      "set-size manipulation"
    ]
  },
  "stimuli": [
    {
      "id": "conjunction",
      "description": "Conjunction-search array: contains white horizontally-rotated distractors plus black distractors (and possibly a white vertical target); participant judges target present/absent.",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('#jspsych-html-keyboard-response-stimulus #white-distractor-element')",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "conjunction",
        "response_key_js": "(() => { const c = document.querySelector('#jspsych-html-keyboard-response-stimulus'); if (!c) return null; const present = c.querySelector('#target') !== null; const g = (window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1; const presentKey = (g >= 0 && g <= 4) ? '.' : ','; const absentKey = (g >= 0 && g <= 4) ? ',' : '.'; return present ? presentKey : absentKey; })()"
      }
    },
    {
      "id": "feature",
      "description": "Feature-search array: distractors are all black rectangles (no white distractors); a single white vertical target may or may not be present; participant judges target present/absent.",
      "detection": {
        "method": "js_eval",
        "selector": "(!!document.querySelector('#jspsych-html-keyboard-response-stimulus .container') && !document.querySelector('#jspsych-html-keyboard-response-stimulus #white-distractor-element'))",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": null,
        "condition": "feature",
        "response_key_js": "(() => { const c = document.querySelector('#jspsych-html-keyboard-response-stimulus'); if (!c) return null; const present = c.querySelector('#target') !== null; const g = (window.efVars && typeof window.efVars.group_index === 'number') ? window.efVars.group_index : 1; const presentKey = (g >= 0 && g <= 4) ? '.' : ','; const absentKey = (g >= 0 && g <= 4) ? ',' : '.'; return present ? presentKey : absentKey; })()"
      }
    }
  ],
