{
  "reference_csv": "data/human/stop_signal_rdoc.csv",
  "notes": "RDoC battery stop-signal session-level summaries. stop_accuracy = proportion of stop trials successfully inhibited = bot-side omission rate on the stop condition. SSRT is the MEAN method (go_rt - mean_SSD) on both sides; the summaries cannot support the integration method.",
  "metrics": {
    "go_rt": {
      "bot": {"kind": "rt_mean", "condition": "go", "correct_only": true},
      "human": {"column": "go_rt"}
    },
    "go_rt_all_responses": {
      "bot": {"kind": "rt_mean", "condition": "go", "correct_only": false},
      "human": {"column": "go_rt_all_responses"}
    },
    "go_accuracy": {
      "bot": {"kind": "accuracy", "condition": "go"},
      "human": {"column": "go_accuracy"}
    },
    "go_omission_rate": {
      "bot": {"kind": "omission_rate", "condition": "go"},
      "human": {"column": "go_omission_rate"}
    },
    "stop_accuracy": {
      "bot": {"kind": "omission_rate", "condition": "stop"},
      "human": {"column": "stop_accuracy"}
    },
    "mean_stop_failure_rt": {
      "bot": {"kind": "rt_mean", "condition": "stop", "correct_only": false},
      "human": {"column": "mean_stop_failure_RT"}
    },
    "mean_ssd": {
      "bot": {"kind": "field_mean", "field": "ssd", "condition": "stop"},
      "human": {"column": "mean_SSD"}
    },
    "ssrt_mean_method": {
      "bot": {"kind": "subtract", "a": "go_rt", "b": "mean_ssd"},
      "human": {"subtract": ["go_rt", "mean_SSD"]}
    }
  }
}
