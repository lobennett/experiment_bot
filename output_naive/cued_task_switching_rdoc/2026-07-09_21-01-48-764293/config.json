      "id": "task_switch_trial",
      "description": "A digit presented as an image inside the response frame; the participant classifies it by the currently cued rule (parity or magnitude) with the comma or period key.",
      "detection": {
        "method": "js_eval",
        "selector": "!!document.querySelector('#jspsych-html-keyboard-response-stimulus img.center')",
        "alt_method": "",
        "pattern": ""
