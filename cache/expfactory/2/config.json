      },
      {
        "task_switch": "switch",
        "cue_switch": "switch"
      }
    ],
    "correct_response_determination": "Use js_eval to access window.correctResponse which is set by setStims() before each trial. The correct key is stored there. Alternatively, determine from window.currTask and window.currStim.number using the responseMappings object.",
    "attention_check_handling": "Read the question text to determine which key to press. Questions ask to press specific letter keys (q,p,r,s,t,j,k,e,m,i,u) or positional alphabet keys (a,b,c,x,y,z)."
  },
  "runtime": {
    "timing": {
