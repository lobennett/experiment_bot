{
  "task": {
    "name": "Cued Task Switching",
    "platform": "psytoolkit",
    "constructs": [
      "cognitive flexibility",
      "task switching",
      "executive function",
      "set shifting"
    ],
    "reference_literature": [
      "Monsell, S. (2003). Task switching. Trends in Cognitive Sciences, 7(3), 134-140.",
      "Meiran, N. (1996). Reconfiguration of processing mode prior to task performance. Journal of Experimental Psychology: Learning, Memory, and Cognition, 22(6), 1423-1442."
    ]
  },
  "stimuli": [
    {
      "id": "respond_left",
      "description": "Stimulus requiring left key (B) - yellow color or circle shape",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { try { return (typeof task_color !== 'undefined' && task_color.step === 5 && typeof tablerow !== 'undefined' && t_colortasktable[tablerow].c3 === 1) || (typeof task_shape !== 'undefined' && task_shape.step === 5 && typeof tablerow !== 'undefined' && t_shapetasktable[tablerow].c3 === 1); } catch(e) { return false; } })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "b",
        "condition": "go_left"
      }
    },
    {
      "id": "respond_right",
      "description": "Stimulus requiring right key (N) - blue color or rectangle shape",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { try { return (typeof task_color !== 'undefined' && task_color.step === 5 && typeof tablerow !== 'undefined' && t_colortasktable[tablerow].c3 === 2) || (typeof task_shape !== 'undefined' && task_shape.step === 5 && typeof tablerow !== 'undefined' && t_shapetasktable[tablerow].c3 === 2); } catch(e) { return false; } })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "n",
        "condition": "go_right"
      }
    }
  ],
  "response_distributions": {
    "go_correct": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 550,
        "sigma": 80,
        "tau": 120
      },
      "unit": "ms"
    },
    "go_error": {
      "distribution": "ex_gaussian",
      "params": {
        "mu": 500,
        "sigma": 90,
        "tau": 130
      },
      "unit": "ms"
    }
  },
  "performance": {
    "go_accuracy": 0.92,
    "stop_accuracy": 0.5,
    "omission_rate": 0.03,
    "practice_accuracy": 0.85
  },
