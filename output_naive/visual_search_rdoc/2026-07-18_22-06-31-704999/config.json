  "task_specific": {
    "key_map": {
      "feature": "dynamic",
      "conjunction": "dynamic"
    },
    "trial_timing": {
      "max_response_time_ms": 2000,
      "stimulus_duration_ms": 1500,
      "trial_duration_ms": 2000,
      "fixation_duration_ms": 500
    },
    "counterbalancing": {
      "variable": "window.group_index",
      "default": 1,
      "note": "group_index 0-4 maps target-present -> period '.' (middle finger) and target-absent -> comma ',' (index finger); group_index 5-14 reverses this (present -> ',', absent -> '.'). Derived from getKeyMappingForTask() and testTrial.on_finish correct_response assignment. No live window.correctResponse is exposed, so response_key_js computes the key from DOM target presence + group_index."
    },
    "design": {
      "conditions": [
        "feature",
        "conjunction"
      ],
      "set_sizes": [
        8,
        24
      ],
      "target": [
