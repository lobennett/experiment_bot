  "runtime": {
    "phase_detection": {
      "method": "js_eval",
      "complete": "!!document.querySelector('#finished_message') || !!document.querySelector('#next_experiment_button') || (!!document.body && /Experiment Complete/i.test(document.body.innerText))",
      "test": "window.expStage === 'test'",
      "loading": "!!document.querySelector('#jspsych-fullscreen-btn') || (!document.querySelector('#jspsych-content') && !document.querySelector('.jspsych-display-element'))",
      "instructions": "!!document.querySelector('#jspsych-instructions-next') || !!document.querySelector('.jspsych-instructions-nav')",
      "practice": "window.expStage === 'practice'",
      "feedback": "(() => { const s = document.querySelector('#jspsych-html-keyboard-response-stimulus, #jspsych-content'); if (!s) return false; const t = s.innerText || ''; return /Press .*enter.*to (begin|continue)|completed \\d+ out of|read your feedback|start the test portion|repeat the practice/i.test(t); })()",
      "attention_check": "!!document.querySelector('#jspsych-attention-check-rdoc-stimulus')"
    },
    "timing": {
      "poll_interval_ms": 20,
      "max_no_stimulus_polls": 600,
      "stuck_timeout_s": 10.0,
      "completion_wait_ms": 6000,
      "feedback_delay_ms": 2000,
      "omission_wait_ms": 2000,
      "rt_floor_ms": 150.0,
      "rt_cap_fraction": 0.9,
      "response_window_js": "!!document.querySelector('#jspsych-html-keyboard-response-stimulus .container .box')",
      "trial_context_js": "(() => { return (window.condition || '') + ' | n=' + (window.numberStim || '') + ' | target=' + (typeof window.trialTargetPresent !== 'undefined' ? window.trialTargetPresent : ''); })()",
      "viewport": {
        "width": 1280,
        "height": 800
      },
      "navigation_delay_ms": 1000,
      "attention_check_delay_ms": 2000,
      "completion_settle_ms": 2000,
      "trial_end_timeout_s": 8.0,
      "cdp_dwell_ms": 300.0,
      "trial_marker_js": "",
      "records_js": ""
    },
    "advance_behavior": {
      "pre_keypress_js": "",
      "advance_keys": [
        "Enter"
      ],
      "exit_pager_key": "",
      "advance_interval_polls": 100,
      "feedback_selectors": [
        "#jspsych-instructions-next",
        ".jspsych-btn"
      ],
      "feedback_fallback_keys": [
        "Enter"
      ]
    },
    "trial_interrupt": {
      "detection_condition": "",
      "failure_rt_key": "",
      "failure_rt_cap_fraction": 0.0,
      "inhibit_wait_ms": 0
    },
    "data_capture": {
      "method": "js_expression",
      "expression": "jsPsych.data.get().json()",
      "format": "json",
      "wait_ms": 1000
    },
    "attention_check": {
      "detection_selector": "#jspsych-attention-check-rdoc-stimulus",
      "text_selector": "#jspsych-attention-check-rdoc-stimulus",
      "response_js": "(() => { const el = document.querySelector('#jspsych-attention-check-rdoc-stimulus'); if (!el) return null; const t = (el.textContent || '').toLowerCase(); const alphabet = 'abcdefghijklmnopqrstuvwxyz'; let m = t.match(/press the ([a-z]) key/); if (m) return m[1]; if (/last letter/.test(t)) { if (/third to last/.test(t)) return alphabet[alphabet.length - 3]; if (/second to last/.test(t)) return alphabet[alphabet.length - 2]; return alphabet[alphabet.length - 1]; } const ord = {first:1, second:2, third:3, fourth:4, fifth:5}; m = t.match(/(first|second|third|fourth|fifth) letter/); if (m) return alphabet[ord[m[1]] - 1]; return null; })()",
      "stimulus_conditions": [
        "attention_check",
        "attention_check_response"
      ]
    },
    "navigation_stimulus_condition": "",
    "delivery_channel": "cdp",
    "calibration_n_keys": 30,
    "platform_export": {
      "row_filter": {
        "equals": {
          "trial_id": "test_trial"
        }
      },
      "fields": {
        "condition": {
          "column": "condition"
        },
        "rt": {
          "column": "rt",
          "parse": "float"
        },
        "correct": {
          "column": "correct_trial",
          "parse": "truthy"
        },
        "target_present": {
          "column": "target_present",
          "parse": "float"
        },
        "num_stimuli": {
          "column": "num_stimuli",
          "parse": "float"
        }
      }
    }
