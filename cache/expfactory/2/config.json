  "task_specific": {
    "task_type": "cued_task_switching",
    "tasks": {
      "parity": {
        "cues": [
          "Parity",
          "Odd-Even"
        ],
        "responses": {
          "even": "depends_on_group_index",
          "odd": "depends_on_group_index"
        }
      },
      "magnitude": {
        "cues": [
          "Magnitude",
          "High-Low"
        ],
        "responses": {
          "higher_than_5": "depends_on_group_index",
          "lower_than_5": "depends_on_group_index"
        }
      }
    },
    "response_keys": [
      ",",
      "."
    ],
    "group_index_mappings": {
      "0_to_4": {
        "higher": ",",
        "lower": ".",
        "odd": ",",
        "even": "."
      },
      "5_to_9": {
        "higher": ",",
        "lower": ".",
        "odd": ".",
        "even": ","
      },
      "10_to_14": {
        "higher": ".",
        "lower": ",",
        "odd": ".",
        "even": ","
      }
    },
    "default_group_index": 1,
    "response_logic": "Read currTask and currStim.number from window scope. If currTask=='parity': check if number is even/odd. If currTask=='magnitude': check if number >5 or <5. Map to comma/period based on responseMappings.",
