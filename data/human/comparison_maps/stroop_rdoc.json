{
  "reference_csv": "data/human/stroop_rdoc.csv",
  "notes": "RDoC battery Stroop session-level summaries. RT columns are mean RT on correct trials; accuracy is among responded trials; omission rate over all trials. stroop_effect is derived row-wise (incongruent - congruent).",
  "metrics": {
    "congruent_rt": {
      "bot": {"kind": "rt_mean", "condition": "congruent", "correct_only": true},
      "human": {"column": "congruent_rt"}
    },
    "incongruent_rt": {
      "bot": {"kind": "rt_mean", "condition": "incongruent", "correct_only": true},
      "human": {"column": "incongruent_rt"}
    },
    "stroop_effect": {
      "bot": {"kind": "subtract", "a": "incongruent_rt", "b": "congruent_rt"},
      "human": {"subtract": ["incongruent_rt", "congruent_rt"]}
    },
    "congruent_accuracy": {
      "bot": {"kind": "accuracy", "condition": "congruent"},
      "human": {"column": "congruent_accuracy"}
    },
    "incongruent_accuracy": {
      "bot": {"kind": "accuracy", "condition": "incongruent"},
      "human": {"column": "incongruent_accuracy"}
    },
    "congruent_omission_rate": {
      "bot": {"kind": "omission_rate", "condition": "congruent"},
      "human": {"column": "congruent_omission_rate"}
    },
    "incongruent_omission_rate": {
      "bot": {"kind": "omission_rate", "condition": "incongruent"},
      "human": {"column": "incongruent_omission_rate"}
    }
  }
}
