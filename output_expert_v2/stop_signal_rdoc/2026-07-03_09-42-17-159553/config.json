      "feedback": "(() => { const c = document.querySelector('#jspsych-content'); if (!c) return false; const t = c.innerText || ''; if (document.querySelector('#jspsych-stop-signal-stimulus') || document.querySelector('#jspsych-instructions-next')) return false; return /press\\s+.?enter.?\\s+to\\s+(begin|continue)/i.test(t) || t.includes('read your feedback') || /You have completed/i.test(t) || /Correct!|Incorrect|Respond Faster|There was a star/.test(t); })()",
