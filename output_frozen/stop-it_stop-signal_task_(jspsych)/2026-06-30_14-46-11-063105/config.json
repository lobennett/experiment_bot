  "runtime": {
    "phase_detection": {
      "method": "js_eval",
      "complete": "/Thank you for your participation/.test(document.body.innerText||\"\")",
      "test": "typeof window.block_ind!==\"undefined\"&&window.block_ind>0",
      "loading": "(typeof window.jsPsych===\"undefined\")||!document.querySelector(\"#jspsych-content\")",
      "instructions": "!!document.querySelector(\"#jspsych-fullscreen-btn\")||!!document.querySelector(\"#jspsych-instructions-next\")||/Press space to begin/.test(document.body.innerText||\"\")",
      "practice": "window.block_ind===0",
      "feedback": "/Average response time|next block starts|Press space to continue|GO TRIALS|STOP-SIGNAL TRIALS/.test(document.body.innerText||\"\")",
      "attention_check": "false"
    },
    "timing": {
