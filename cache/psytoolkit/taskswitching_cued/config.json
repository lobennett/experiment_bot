{
  "task": {
    "name": "Cued Task Switching",
    "platform": "psytoolkit",
    "constructs": [
      "cognitive flexibility",
      "task switching",
      "executive function",
      "set shifting"
    ],
    "reference_literature": [
      "Monsell, S. (2003). Task switching. Trends in Cognitive Sciences, 7(3), 134-140.",
      "Meiran, N. (1996). Reconfiguration of processing mode prior to task performance. Journal of Experimental Psychology: Learning, Memory, and Cognition, 22(6), 1423-1442."
    ]
  },
  "stimuli": [
    {
      "id": "color_left",
      "description": "Color task requiring left key (B) - yellow color",
      "detection": {
        "method": "js_eval",
        "selector": "(() => { try { var cs = typeof task_color !== 'undefined' ? task_color.step : -1; return cs >= 5 && cs <= 8 && typeof tablerow !== 'undefined' && t_colortasktable[tablerow].c3 === 1; } catch(e) { return false; } })()",
        "alt_method": "",
        "pattern": ""
      },
      "response": {
        "key": "b",
        "condition": "color_left"
      }
    },
    {
